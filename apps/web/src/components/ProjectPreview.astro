---
import type { CollectionEntry } from 'astro:content';
import ArrowRight from '@icons/ArrowRight.astro';

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
---

<article class="group border border-[var(--color-border)] p-6 transition-colors hover:border-[var(--color-accent)]">
  <a href={`/projects/${project.id}`} class="block no-underline">
    <h3 class="font-sans text-xl font-600 text-[var(--color-fg)]">
      {project.data.title}
    </h3>
    <p class="mt-3 text-sm leading-relaxed text-[var(--color-muted)]">
      {project.data.description}
    </p>
    {project.data.technologies.length > 0 && (
      <div class="mt-4 flex flex-wrap gap-2">
        {project.data.technologies.map((tech) => (
          <span class="border border-[var(--color-border)] bg-[var(--color-surface)] px-2.5 py-1 font-sans text-xs text-[var(--color-muted)]">
            {tech}
          </span>
        ))}
      </div>
    )}
    <div class="mt-4 flex items-center gap-1 font-sans text-sm font-600 text-[var(--color-accent)]">
      View project
      <ArrowRight class="h-4 w-4 transition-transform group-hover:translate-x-1" />
    </div>
  </a>
</article>
