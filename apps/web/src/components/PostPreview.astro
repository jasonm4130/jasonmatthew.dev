---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from './FormattedDate.astro';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
---

<article class="reveal border-b border-[var(--color-border)] py-6">
  <a href={`/blog/${post.id}`} class="group block no-underline">
    <div class="flex items-baseline justify-between gap-4">
      <h3
        class="font-600 font-sans text-lg text-[var(--color-fg)] transition-colors group-hover:text-[var(--color-accent)]"
      >
        {post.data.title}
        <span
          class="inline-block translate-x-0 opacity-0 transition-all motion-safe:group-hover:translate-x-1 motion-safe:group-hover:opacity-100"
          aria-hidden="true">&nbsp;&rarr;</span
        >
      </h3>
      <span class="shrink-0 font-sans text-sm text-[var(--color-muted)]">
        <FormattedDate date={post.data.publishDate} />
      </span>
    </div>
    {post.data.excerpt && <p class="mt-2 text-sm leading-relaxed text-[var(--color-muted)]">{post.data.excerpt}</p>}
    {
      post.data.tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-2">
          {post.data.tags.map((tag) => (
            <span class="font-sans text-xs text-[var(--color-muted)]">#{tag}</span>
          ))}
        </div>
      )
    }
  </a>
</article>
