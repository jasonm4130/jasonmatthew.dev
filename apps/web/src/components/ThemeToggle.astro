---
import Lightbulb from '@icons/Lightbulb.astro';
---

<button
  id="theme-toggle"
  type="button"
  class="theme-toggle flex h-9 w-9 items-center justify-center rounded-full text-[var(--color-muted)] transition-[transform,color] duration-200 hover:scale-105 hover:text-[var(--color-fg)]"
  aria-label="Toggle theme"
>
  <Lightbulb class="h-5 w-5" />
</button>
