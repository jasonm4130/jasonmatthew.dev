---
import Sun from '@icons/Sun.astro';
import Moon from '@icons/Moon.astro';
---

<button
  id="theme-toggle"
  type="button"
  class="relative flex h-9 w-9 items-center justify-center rounded-full text-[var(--color-muted)] transition-colors hover:text-[var(--color-fg)]"
  aria-label="Toggle theme"
>
  <Sun class="absolute h-5 w-5 opacity-0 transition-opacity duration-300 dark:opacity-100" />
  <Moon class="absolute h-5 w-5 opacity-100 transition-opacity duration-300 dark:opacity-0" />
</button>
