---
import Sun from '@icons/Sun.astro';
import Moon from '@icons/Moon.astro';
---

<button
  id="theme-toggle"
  type="button"
  class="flex h-9 w-9 items-center justify-center rounded-full text-[var(--color-muted)] transition-colors hover:text-[var(--color-fg)]"
  aria-label="Toggle theme"
>
  <Sun class="hidden h-5 w-5 dark:block" />
  <Moon class="block h-5 w-5 dark:hidden" />
</button>
