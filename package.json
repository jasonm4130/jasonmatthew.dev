{
  "name": "jasonmatthew.dev",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{js,mjs,ts,tsx,astro,md,mdx,json,css}\"",
    "format:check": "prettier --check \"**/*.{js,mjs,ts,tsx,astro,md,mdx,json,css}\""
  },
  "devDependencies": {
    "prettier": "^3.2.5",
    "prettier-plugin-astro": "^0.14.0",
    "prettier-plugin-tailwindcss": "^0.6.0",
    "turbo": "^2.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp"
    ]
  },
  "packageManager": "pnpm@10.8.1",
  "volta": {
    "node": "22.22.2"
  }
}
