{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "generate:og": {
      "inputs": ["scripts/**", "packages/content/**"],
      "outputs": [
        "apps/web/public/og/**",
        "apps/web/public/favicon-512.png",
        "apps/web/public/apple-touch-icon.png",
        "apps/web/public/favicon.svg"
      ]
    },
    "build": {
      "dependsOn": ["^build", "generate:og"],
      "inputs": ["src/**", "public/**", "astro.config.*", "tsconfig.json", "package.json"],
      "outputs": ["dist/**", ".astro/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["^build"]
    }
  }
}
